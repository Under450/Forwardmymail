rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Does the signed-in user own this resource?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the signed-in user a verified staff member?
    // Staff must have a document in the /staff collection with their uid
    function isStaff() {
      return isAuth() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // Is the signed-in user an admin?
    // Admin is defined by custom claim OR hardcoded UID
    function isAdmin() {
      return isAuth() && (
        request.auth.token.admin == true ||
        request.auth.uid == '1k8MzhKRfbZSAoBWKR7apEom0S83'
      );
    }

    // Does the incoming data claim to belong to the signed-in user?
    function ownedByMe() {
      return isAuth() &&
        request.resource.data.customerId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    // STAFF COLLECTION
    // Staff docs are read-only to staff themselves;
    // only writable by other staff (e.g. admin adds staff members)
    // ─────────────────────────────────────────────
    match /staff/{staffId} {
      allow read: if isOwner(staffId) || isStaff();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // CUSTOMERS COLLECTION
    // ─────────────────────────────────────────────
    match /customers/{userId} {
      // Customer can read their own doc
      allow read: if isOwner(userId);

      // Customer can create their own doc (signup flow)
      allow create: if isOwner(userId);

      // Customer can only update these specific fields
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['forwardingAddress', 'forwardingFrequency', 'notificationPrefs']);

      // Staff can update anything
      allow update: if isStaff();

      // Only staff can delete customer docs
      allow delete: if isStaff();

      // Staff can read all customer docs (for the staff portal list)
      allow read: if isStaff();
    }

    // ─────────────────────────────────────────────
    // MAIL COLLECTION
    // ─────────────────────────────────────────────
    match /mail/{mailId} {
      // Customer can read their own mail items
      allow read: if isAuth() && resource.data.customerId == request.auth.uid;

      // Customer can update ONLY whitelisted fields on their own mail.
      // Prevents customer from rewriting cost, sender, description, customerId, etc.
      // Whitelisted fields match what fmm-app.html actually writes (requestAction).
      allow update: if isAuth()
        && resource.data.customerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'actionRequestedAt', 'actionRequestedBy', 'read', 'viewed', 'archived']);

      // Only staff can create or delete mail items
      allow create: if isStaff();
      allow delete: if isStaff();

      // Staff can read and write all mail (unrestricted)
      allow read, write: if isStaff();
    }

    // ─────────────────────────────────────────────
    // MAIL REQUESTS COLLECTION
    // Customers submit post/shred/store requests;
    // staff read and process them
    // ─────────────────────────────────────────────
    match /mailRequests/{reqId} {
      // Customer can create a request for their own mail
      allow create: if isAuth() && ownedByMe();

      // Customer can read their own requests
      allow read: if isAuth() && resource.data.customerId == request.auth.uid;

      // Staff can read all requests and update them (mark processed, etc.)
      allow read, write: if isStaff();
    }

    // ─────────────────────────────────────────────
    // CONTACT REQUESTS COLLECTION
    // Customers submit support messages
    // ─────────────────────────────────────────────
    match /contactRequests/{docId} {
      // Any authenticated customer can create a contact request
      allow create: if isAuth();

      // Customer can read their own contact requests
      allow read: if isAuth() && resource.data.customerId == request.auth.uid;

      // Staff can read and update all contact requests
      allow read, write: if isStaff();
    }

    // ─────────────────────────────────────────────
    // STAFF NOTIFICATIONS COLLECTION
    // Written by the fmm-app when customers take actions;
    // read and managed by staff
    // ─────────────────────────────────────────────
    match /staff_notifications/{notifId} {
      // Any authenticated customer can create a notification
      allow create: if isAuth();

      // Staff can read, update and delete notifications
      allow read, write: if isStaff();
    }

    // ─────────────────────────────────────────────
    // CJ CONTROL PANEL STATE
    // ─────────────────────────────────────────────
    match /panel_state/{doc} {
      allow read, write: if isAuth() && request.auth.uid == 'pY80AVfY9teBlcBD8b8EUo3rORm2';
    }

    // ─────────────────────────────────────────────
    // TERMS ACCEPTANCES COLLECTION
    // CJ owner only — legal records
    // ─────────────────────────────────────────────
    match /termsAcceptances/{docId} {
      allow read, write, delete: if isAuth() && request.auth.uid == 'pY80AVfY9teBlcBD8b8EUo3rORm2';
    }

    // ─────────────────────────────────────────────
    // COUNTERS (used for TCA ref generation)
    // ─────────────────────────────────────────────
    match /_counters/{docId} {
      allow read, write: if isAuth() && request.auth.uid == 'pY80AVfY9teBlcBD8b8EUo3rORm2';
    }

    // ─────────────────────────────────────────────
    // EMAIL LOGS COLLECTION
    // Written by the stripe-webhook Cloud Functions (sendMailLogged helper).
    // Customers can read their own log entries; staff can read all (cj-portal timeline view).
    // No client-side writes - only server-side via Cloud Functions.
    // ─────────────────────────────────────────────
    match /email_logs/{logId} {
      allow read: if isStaff();
      allow read: if isAuth() && resource.data.customerEmail == request.auth.token.email;
      allow write: if false; // only Cloud Functions write (via admin SDK which bypasses rules)
    }

    // ─────────────────────────────────────────────
    // CONSENTS COLLECTION
    // Immutable audit log of consent events (terms acceptance, immediate-performance
    // acknowledgment, etc.). Customers can create their own. Nobody can update or
    // delete — staff can only read (for audit / dispute response).
    // ─────────────────────────────────────────────
    match /consents/{consentId} {
      // Customer creates their own consent record on signup; payload must be tagged with their uid
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      // Customer can read their own records
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      // Staff can read all (audit/dispute defence)
      allow read: if isStaff();
      // Immutable — no updates, no deletes
      allow update: if false;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────
    // DIDIT WEBHOOK EVENTS (idempotency log)
    // Written only by diditWebhook Cloud Function (admin SDK bypasses rules).
    // Staff can read for debug.
    // ─────────────────────────────────────────────
    match /didit_webhook_events/{eventId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // ─────────────────────────────────────────────
    // DENY EVERYTHING ELSE
    // ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
