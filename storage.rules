rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────
    // HELPER: is the user a verified staff member?
    // Checks for a doc in /staff/{uid} in Firestore
    // ─────────────────────────────────────────────
    function isStaff() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/staff/$(request.auth.uid));
    }

    // ─────────────────────────────────────────────
    // HELPER: validate upload size + MIME
    // 25 MB max; PDF or image only
    // ─────────────────────────────────────────────
    function validUpload() {
      return request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // ─────────────────────────────────────────────
    // MAIL SCANS (uploaded by staff portal)
    // Path: mail-scans/{customerId}/{filename}
    // ─────────────────────────────────────────────
    match /mail-scans/{customerId}/{fileName} {
      // Customer can only read their own scans
      allow read: if request.auth != null && request.auth.uid == customerId;
      // Staff can read; writes must pass size + MIME validation
      allow read: if isStaff();
      allow write: if isStaff() && validUpload();
      allow delete: if isStaff();
    }

    // ─────────────────────────────────────────────
    // SCANS (newer path used by fmm-app)
    // Path: scans/{customerId}/{filename}
    // ─────────────────────────────────────────────
    match /scans/{customerId}/{fileName} {
      // Customer can only read their own scans
      allow read: if request.auth != null && request.auth.uid == customerId;
      // Staff can read; writes must pass size + MIME validation
      allow read: if isStaff();
      allow write: if isStaff() && validUpload();
      allow delete: if isStaff();
    }

    // ─────────────────────────────────────────────
    // TCA CERTIFICATES (CJ owner only)
    // Path: tca-certificates/{filename}
    // ─────────────────────────────────────────────
    match /tca-certificates/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == 'pY80AVfY9teBlcBD8b8EUo3rORm2';
    }

    // ─────────────────────────────────────────────
    // DENY EVERYTHING ELSE
    // ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
